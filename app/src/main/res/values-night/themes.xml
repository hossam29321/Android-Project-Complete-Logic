<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark mode theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Dark mode colors -->
        <item name="colorPrimary">#42A5F5</item>
        <item name="colorPrimaryDark">#1976D2</item>
        <item name="colorAccent">#42A5F5</item>
        <item name="colorOnPrimary">@android:color/black</item>

        <!-- Background colors for dark mode -->
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>

        <!-- Text colors for dark mode -->
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#B0B0B0</item>

        <!-- Input field colors -->
        <item name="colorControlNormal">#808080</item>
        <item name="colorControlActivated">#42A5F5</item>
        <item name="colorControlHighlight">#42A5F5</item>
    </style>

    <!-- Theme for activities that need no action bar -->
    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Theme for fullscreen activities (like your game) -->
    <style name="AppTheme.Fullscreen" parent="AppTheme.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>