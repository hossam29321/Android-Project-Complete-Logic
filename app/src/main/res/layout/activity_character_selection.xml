<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0e27"
    android:padding="0dp">

    <!-- Header with gradient-like background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1a1f3a"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CHARACTER SHOP"
            android:textSize="32sp"
            android:textColor="#00ff88"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose your hero and unlock special perks"
            android:textSize="13sp"
            android:textColor="#00ff88"
            android:gravity="center"
            android:layout_marginTop="5dp"
            android:alpha="0.7" />
    </LinearLayout>

    <!-- Character Carousel Section -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#0f1629"
        android:layout_margin="16dp"
        android:elevation="4dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/character_buttons_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp" />
        </HorizontalScrollView>
    </FrameLayout>

    <!-- Details Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Selected Indicator -->
        <FrameLayout
            android:id="@+id/selected_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a6b2e"
            android:padding="10dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ CHARACTER SELECTED"
                android:textColor="#00ff88"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center" />
        </FrameLayout>

        <!-- Character Name and Cost -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/character_name_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Character Name"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/character_cost_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2500 coins"
                android:textSize="14sp"
                android:textColor="#ff6b00"
                android:textStyle="bold"
                android:background="#2a1a00"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <!-- Character Details with card style -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1a1f3a"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/character_details_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Character stats will appear here"
                        android:textSize="13sp"
                        android:textColor="#cccccc"
                        android:lineSpacingMultiplier="1.6"
                        android:typeface="monospace" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:spacing="12dp">

            <Button
                android:id="@+id/action_button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="SELECT"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#00cc55"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/back_button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="BACK"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#444444"
                android:layout_marginStart="6dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
